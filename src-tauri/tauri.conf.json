{
  "build": {
    "frontendDist": "./dist"
  },
  "bundle": {
    "active": true,
    "targets": "dmg",
    "resources": [
      "dist/assets/ollama.svg",
      "dist/assets/javascript.svg",
      "dist/assets/tauri.svg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "productName": "mac-stats",
  "mainBinaryName": "mac_stats",
  "identifier": "com.raro42.mac-stats",
  "plugins": {},
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "mac-stats",
        "width": 300,
        "height": 100,
        "visible": false,
        "useHttpsScheme": true
      }
    ]
  }
}